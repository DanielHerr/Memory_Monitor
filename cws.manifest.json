{
	"manifest_version": 3,
	"name": "Memory Monitor",
	"version": "12.1.3.2",
	"version_name": "12.1 (2026.5.23, Mv3, Chrome 109+)",
	"description": "Displays RAM Usage Information",
	"author": "Daniel Herr",
	"homepage_url": "https://danielherr.software/Memory_Monitor",
	"offline_enabled": true,
	"icons": { "128": "icon.png" },
	"action": { "default_popup": "popup/popup.html" },
	"background": { "service_worker": "background/background.js" },
	"options_page": "Settings/Settings.html",
	"permissions": [ "system.memory", "storage", "notifications", "system.display", "contextMenus", "offscreen" ],
	"minimum_chrome_version": "109"
}